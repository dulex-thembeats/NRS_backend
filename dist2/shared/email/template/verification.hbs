<!-- src/shared/email/templates/verification.hbs -->

<html>
  <head>
    <meta charset='utf-8' />
    <title>Verify Your Email</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        background: #28a745;
        color: white;
        padding: 20px;
        text-align: center;
      }
      .content {
        padding: 20px;
        background: #f9f9f9;
      }
      .button {
        display: inline-block;
        padding: 12px 24px;
        background: #28a745;
        color: white;
        text-decoration: none;
        border-radius: 4px;
        margin: 10px 0;
      }
      .footer {
        text-align: center;
        padding: 20px;
        font-size: 12px;
        color: #666;
      }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='header'>
        <h1>Verify Your Email</h1>
      </div>
      <div class='content'>
        <h2>Hello {{businessName}}!</h2>
        <p>Thank you for signing up! Please verify your email address by entering the following OTP in the app:</p>
        <h2 style="text-align: center; font-size: 32px; letter-spacing: 5px; color: #28a745;">{{verificationToken}}</h2>
        <p>If you didn't create an account with us, you can safely ignore this
          email.</p>
      </div>
      <div class='footer'>
        <p>&copy; 2026 Genius-Excel. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>