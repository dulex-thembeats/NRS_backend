<!-- src/shared/email/templates/welcome.hbs -->

<html>
  <head>
    <meta charset='utf-8' />
    <title>Welcome to Genius-Excel</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        background: #007bff;
        color: white;
        padding: 20px;
        text-align: center;
      }
      .content {
        padding: 20px;
        background: #f9f9f9;
      }
      .button {
        display: inline-block;
        padding: 12px 24px;
        background: #007bff;
        color: white;
        text-decoration: none;
        border-radius: 4px;
        margin: 10px 0;
      }
      .footer {
        text-align: center;
        padding: 20px;
        font-size: 12px;
        color: #666;
      }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='header'>
        <h1>Welcome to Genius-Excel!</h1>
      </div>
      <div class='content'>
        <h2>Hello {{businessName}}!</h2>
        <p>Welcome to our platform! Your account has been successfully created</p>
        <p>You can now log in to your account and start exploring all the
          features we have to offer.</p>
        <a href='{{loginUrl}}' class='button'>Log In to Your Account</a>
        <p>If you have any questions, feel free to reach out to our support
          team.</p>
      </div>
      <div class='footer'>
        <p>&copy; 2026 Genius-Excel. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>